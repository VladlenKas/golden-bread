<sukiUI:SukiWindow 
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:suki="https://github.com/kikipoulet/SukiUI"
        xmlns:sukiUI="clr-namespace:SukiUI.Controls;assembly=SukiUI"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:theme="clr-namespace:SukiUI.Theme;assembly=SukiUI"
        xmlns:vm="using:GoldenBread.Desktop.Features.Menu"
        x:Class="GoldenBread.Desktop.Features.Menu.MenuWindow"
        x:DataType="vm:MenuWindowViewModel"
        Icon="/Assets/Icons/logo.ico"
        Title="GoldenBread UI - Меню"
        WindowStartupLocation="CenterScreen"
        Width="1000" Height="650">
  
    <sukiUI:SukiWindow.Hosts>
		<sukiUI:SukiDialogHost Manager="{Binding DialogManager}"/>
	</sukiUI:SukiWindow.Hosts>

    <StackPanel>
		
    </StackPanel>

</sukiUI:SukiWindow>
