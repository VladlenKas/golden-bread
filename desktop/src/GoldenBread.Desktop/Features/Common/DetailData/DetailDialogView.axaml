<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 xmlns:vm="using:GoldenBread.Desktop.Features.Common.DetailData"
			 xmlns:suki="https://github.com/kikipoulet/SukiUI"
			 x:Class="GoldenBread.Desktop.Features.Common.DetailData.DetailDialogView"
			 x:DataType="vm:DetailDialogViewModel">	

	<ScrollViewer Width="400" MaxHeight="900">

		<StackPanel>

			<ItemsControl ItemsSource="{Binding Sections}">
				<ItemsControl.ItemTemplate>
					<DataTemplate>

						<suki:GlassCard Margin="0 10">
							<Expander Header="{Binding Header}"
									  IsExpanded="True">

								<ItemsControl ItemsSource="{Binding Fields}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>

											<TextBox Text="{Binding Value}"
													 Classes="NoShadow"
													 VerticalContentAlignment="Top"
													 TextWrapping="WrapWithOverflow"
													 suki:TextBoxExtensions.Prefix="{Binding Label, StringFormat='{}{0}:'}" />

										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>

							</Expander>
						</suki:GlassCard>

					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</StackPanel>


	</ScrollViewer>

</UserControl>
