<sukiUI:SukiWindow
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:suki="https://github.com/kikipoulet/SukiUI"
xmlns:sukiUI="clr-namespace:SukiUI.Controls;assembly=SukiUI"
xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
xmlns:theme="clr-namespace:SukiUI.Theme;assembly=SukiUI"
xmlns:vm="using:GoldenBread.Desktop.Features.Menu"
x:Class="GoldenBread.Desktop.Features.Menu.MenuWindowView"
x:DataType="vm:MenuWindowViewModel"
Icon="/Assets/Icons/logo.ico"
Title="GoldenBread UI - Меню"
WindowStartupLocation="CenterScreen"
Width="1300" Height="850">

	<sukiUI:SukiWindow.Hosts>
		<sukiUI:SukiDialogHost Manager="{Binding SukiDialogManager}"/>
		<sukiUI:SukiToastHost Manager="{Binding SukiToastManager}"/>
	</sukiUI:SukiWindow.Hosts>

	<Grid ColumnDefinitions="Auto *">

		<!-- Боковая панель с разделами -->
		<suki:SukiSideMenu
			Grid.Column="0"
			ItemsSource="{Binding SidebarSections}"
			SelectedItem="{Binding SelectedSection}">

			<suki:SukiSideMenu.ItemTemplate>
				<DataTemplate>
					<suki:SukiSideMenuItem
						Classes="Compact"
						FontWeight="Regular"
						Header="{Binding Title}">

						<suki:SukiSideMenuItem.Icon>
							<icon:MaterialIcon Kind="{Binding Icon}" />
						</suki:SukiSideMenuItem.Icon>

					</suki:SukiSideMenuItem>
				</DataTemplate>
			</suki:SukiSideMenu.ItemTemplate>

			<suki:SukiSideMenu.FooterContent>
				<Button 
					Margin="36 4"
					Classes="Basic"
					FontWeight="Regular"
					Content="Выйти"
					HorizontalContentAlignment="Left"
					Command="{Binding LogoutCommand}"
					theme:ButtonExtensions.ShowProgress="{Binding IsLoading}"
					suki:ButtonExtensions.Icon="{icon:MaterialIconExt Kind=Logout}"/>
			</suki:SukiSideMenu.FooterContent>
		</suki:SukiSideMenu>

		<!-- Основной контент справа от меню -->
		<TabControl
			Grid.Column="1" 
			Margin="24"
			ItemsSource="{Binding SectionPages}"
			SelectedItem="{Binding ActivePage}">

			<TabControl.ItemTemplate>
				<DataTemplate>
					<TextBlock Text="{Binding DisplayName}" />
				</DataTemplate>
			</TabControl.ItemTemplate>
		</TabControl>
	</Grid>

</sukiUI:SukiWindow>
