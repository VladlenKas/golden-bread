<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:suki="https://github.com/kikipoulet/SukiUI"
			 xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
			 xmlns:vm="using:GoldenBread.Desktop.Features.Production.OrdersList.ViewModels"
			 xmlns:forms="using:GoldenBread.Desktop.Features.Production.OrdersList.Forms"
			 xmlns:dtos="using:GoldenBread.Desktop.Features.Production.OrdersList.Dtos"
			 x:Class="GoldenBread.Desktop.Features.Production.OrdersList.Views.OrderEditorPageView"
			 x:DataType="vm:OrderEditorPageViewModel"
			 x:CompileBindings="False">

	<suki:BusyArea BusyText="Загрузка..." IsBusy="{Binding IsBusy}">
		<DockPanel HorizontalSpacing="12" VerticalSpacing="16" LastChildFill="True">

			<!-- Кнопки -->
			<StackPanel DockPanel.Dock="Top"
						Orientation="Horizontal"
						HorizontalAlignment="Right"
						Spacing="8">
				<Button Classes="Basic" Content="Назад" Command="{Binding GoBackCommand}"/>
				<Button Classes="Flat"
						Content="Создать заказ"
						IsEnabled="{Binding CanSelectDate}"
						Command="{Binding SaveCommand}"/>
			</StackPanel>

			<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
				<!-- Левая карточка: 3 expander -->
				<ScrollViewer>
					<suki:GlassCard Width="500">
						<StackPanel Spacing="12">

							<!-- Компания -->
							<Expander Header="Выбор компании" IsExpanded="True" ExpandDirection="Down">
								<StackPanel Spacing="8">
									<AutoCompleteBox ItemsSource="{Binding Companies}"
													 SelectedItem="{Binding SelectedCompany}"
													 FilterMode="Contains"
													 MinimumPrefixLength="0"
													 Watermark="Начните вводить название компании..."
													 ValueMemberBinding="{Binding Name}">
										<AutoCompleteBox.ItemTemplate>
											<DataTemplate DataType="dtos:CompanyLookup">
												<TextBlock Text="{Binding Name}"/>
											</DataTemplate>
										</AutoCompleteBox.ItemTemplate>
									</AutoCompleteBox>
								</StackPanel>
							</Expander>

							<!-- Корзина -->
							<Expander Header="Выбранные позиции" IsExpanded="True" ExpandDirection="Down">
								<StackPanel Spacing="8">
									<StackPanel Spacing="8">
										<AutoCompleteBox ItemsSource="{Binding ProductAutocompleteItems}"
														 SelectedItem="{Binding SelectedProductAutoCompleteItem}"
														 FilterMode="Contains"
														 MinimumPrefixLength="0"
														 Watermark="Выберите продукт для добавления"/>
									</StackPanel>

									<StackPanel Spacing="8" IsVisible="{Binding HasCartItems}">
										<ItemsControl x:Name="CartItemsList" ItemsSource="{Binding Form.CartItems}">
											<ItemsControl.ItemTemplate>
												<DataTemplate DataType="forms:OrderCartItem">
													<suki:GlassCard Margin="0 8" Padding="20 16">
														<StackPanel Spacing="6">

															<!-- Заголовок: название + удаление -->
															<DockPanel>
																<Button DockPanel.Dock="Right"
																		Classes="Basic"
																		suki:ButtonExtensions.Icon="{icon:MaterialIconExt Kind=Delete}"
																		Command="{Binding #CartItemsList.DataContext.RemoveProductCommand}"
																		CommandParameter="{Binding}"/>
																<TextBlock Text="{Binding ProductName}"
																		   FontWeight="Bold"
																		   Classes="h5"
																		   VerticalAlignment="Center"/>
															</DockPanel>

															<!-- Партия и базовые цены -->
															<DockPanel VerticalSpacing="12" LastChildFill="False">
																<TextBlock DockPanel.Dock="Left" Text="Партия:" VerticalAlignment="Center"/>
																<ComboBox DockPanel.Dock="Left"
																		  ItemsSource="{Binding AvailableBatches}"
																		  SelectedItem="{Binding SelectedBatch}">
																	<ComboBox.ItemTemplate>
																		<DataTemplate>
																			<TextBlock Text="{Binding DisplayText}"/>
																		</DataTemplate>
																	</ComboBox.ItemTemplate>
																</ComboBox>

																<DockPanel DockPanel.Dock="Right">
																	<Button Classes="Basic"
																			suki:ButtonExtensions.Icon="{icon:MaterialIconExt Kind=Minus}"
																			Command="{Binding #CartItemsList.DataContext.DecreaseQuantityCommand}"
																			CommandParameter="{Binding}"/>
																	<TextBlock Text="{Binding Quantity}"
																			   Width="24"
																			   TextAlignment="Center"
																			   VerticalAlignment="Center"/>
																	<Button Classes="Basic"
																			suki:ButtonExtensions.Icon="{icon:MaterialIconExt Kind=Plus}"
																			Command="{Binding #CartItemsList.DataContext.IncreaseQuantityCommand}"
																			CommandParameter="{Binding}"/>
																</DockPanel>
															</DockPanel>

															<!-- Количество партий и итоги -->
															<DockPanel HorizontalSpacing="12" HorizontalAlignment="Right" LastChildFill="False">
																<StackPanel Orientation="Horizontal" Spacing="4">
																	<TextBlock Text="Всего шт:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
																	<TextBlock Text="{Binding TotalUnits}" FontWeight="Bold" VerticalAlignment="Center"/>
																</StackPanel>
																<StackPanel Orientation="Horizontal" Spacing="4">
																	<TextBlock Text="Сумма:" Opacity="0.6" FontSize="12" VerticalAlignment="Center"/>
																	<TextBlock Text="{Binding TotalCost, StringFormat='{}{0:N2} ₽'}"
																			   FontWeight="Bold"
																			   FontSize="16"
																			   VerticalAlignment="Center"
																			   Foreground="{DynamicResource SukiPrimaryColor}"/>
																</StackPanel>
															</DockPanel>

														</StackPanel>
													</suki:GlassCard>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</StackPanel>
							</Expander>
						</StackPanel>
					</suki:GlassCard>
				</ScrollViewer>

				<!-- Правая карточка: дата и итог -->
				<!-- Правая карточка: дата, время, итог -->
				<ScrollViewer>
					<suki:GlassCard Width="340">
						<StackPanel Spacing="16">

							<!-- Дата доставки -->
							<Expander Header="Дата доставки" IsExpanded="True">
								<StackPanel Spacing="12">
									<suki:GlassCard IsEnabled="{Binding CanSelectDate}">
										<Calendar SelectedDate="{Binding SelectedCalendarDate, Mode=TwoWay}"
												  DisplayDateStart="{Binding MinDeliveryDateOffset}"/>
									</suki:GlassCard>

									<!-- Инфобары -->
									<suki:InfoBar Title="Добавьте продукцию"
												  Severity="Information"
												  IsClosable="False"
												  IsOpen="True"
												  IsVisible="{Binding IsCartEmpty}"/>

									<suki:InfoBar Title="Выберите компанию"
												  Severity="Information"
												  IsClosable="False"
												  IsOpen="True"
												  IsVisible="{Binding ShowSelectCompanyInfo}"/>

									<suki:InfoBar IsVisible="{Binding IsOrderTooLarge}"
												  Title="Заказ слишком большой"
												  Message="Невозможно рассчитать дату доставки. Уменьшите количество или измените состав заказа."
												  Severity="Warning"
												  IsClosable="False"/>

									<suki:InfoBar IsVisible="{Binding IsProductionLimitExceeded}"
												  Title="Превышен лимит 8 часов"
												  Message="Уменьшите количество продукции в заказе"
												  Severity="Error"
												  IsClosable="False"/>

									<Separator Margin="12"/>

									<!-- Даты под календарём -->
									<StackPanel IsVisible="{Binding !IsOrderTooLarge}" Spacing="12">
										<DockPanel IsVisible="{Binding !!Form.MinDeliveryDate}">
											<icon:MaterialIcon Kind="CalendarStart" Width="16" Height="16" Opacity="0.5"/>
											<TextBlock Margin="8,0,0,0" Opacity="0.6">Минимальная дата поставки:</TextBlock>
											<TextBlock HorizontalAlignment="Right">
												<TextBlock.Text>
													<MultiBinding StringFormat="{}{0:d}">
														<Binding Path="Form.MinDeliveryDate"/>
													</MultiBinding>
												</TextBlock.Text>
											</TextBlock>
										</DockPanel>
										<DockPanel IsVisible="{Binding !!Form.MaxDeliveryDate}">
											<icon:MaterialIcon Kind="CalendarEnd" Width="16" Height="16" Opacity="0.5"/>
											<TextBlock Margin="8,0,0,0" Opacity="0.6">Максимальная дата поставки:</TextBlock>
											<TextBlock HorizontalAlignment="Right">
												<TextBlock.Text>
													<MultiBinding StringFormat="{}{0:d}">
														<Binding Path="Form.MaxDeliveryDate"/>
													</MultiBinding>
												</TextBlock.Text>
											</TextBlock>
										</DockPanel>

										<DockPanel>
											<StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="6">
												<icon:MaterialIcon Kind="ClockOutline" Width="18" Height="18" Opacity="0.5"/>
												<TextBlock Text="Время производства" Opacity="0.6"/>
											</StackPanel>
											<TextBlock DockPanel.Dock="Right"
													   HorizontalAlignment="Right"
													   >
												<TextBlock.Text>
													<MultiBinding StringFormat="{}{0} / 8ч">
														<Binding Path="FormattedProductionTime"/>
													</MultiBinding>
												</TextBlock.Text>
											</TextBlock>
										</DockPanel>

										<ProgressBar Maximum="480"
													 Value="{Binding TotalProductionTimeMinutes}"
													 Height="8"/>

									</StackPanel>

									<Separator Margin="12 12 12 0"/>

									<Border
									CornerRadius="12"
									Background="{DynamicResource SukiCardBackgroundBrush}">
										<StackPanel>

											<!-- Сводка -->
											<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="8">
												<TextBlock Grid.Row="0" Grid.Column="0" Text="Позиций:" Opacity="0.5"/>
												<TextBlock Grid.Row="0" Grid.Column="1"
														   Text="{Binding Form.CartItems.Count, StringFormat={}{0} шт.}"
														   FontWeight="SemiBold"/>

												<TextBlock Grid.Row="1" Grid.Column="0" Text="Всего единиц:" Opacity="0.5"/>
												<TextBlock Grid.Row="1" Grid.Column="1"
														   Text="{Binding TotalUnits, StringFormat={}{0} шт.}"
														   FontWeight="SemiBold"/>
											</Grid>

											<Separator Margin="12"/>

											<!-- Цена -->
											<DockPanel>
												<TextBlock Text="ИТОГО:" Opacity="0.5" VerticalAlignment="Center"/>
												<TextBlock HorizontalAlignment="Right"
														   Text="{Binding TotalPrice, StringFormat='{}{0:N2} ₽'}"
														   FontSize="24"
														   FontWeight="Bold"
														   Foreground="{DynamicResource SukiPrimaryColor}"/>
											</DockPanel>
										</StackPanel>
									</Border>
								</StackPanel>
							</Expander>

						</StackPanel>
					</suki:GlassCard>
				</ScrollViewer>
			</StackPanel>
		</DockPanel>
	</suki:BusyArea>
</UserControl>