<UserControl 
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:suki="https://github.com/kikipoulet/SukiUI"
    xmlns:sukiUI="clr-namespace:SukiUI.Controls;assembly=SukiUI"
    xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:theme="clr-namespace:SukiUI.Theme;assembly=SukiUI"
    xmlns:vm="using:GoldenBread.Desktop.Features.References.Employees.ViewModels"
    x:Class="GoldenBread.Desktop.Features.References.Employees.Views.EmployeesListPageView"
    x:DataType="vm:EmployeesListPageViewModel"
    x:CompileBindings="False">

    <suki:BusyArea BusyText="Загрузка..." IsBusy="{Binding IsBusy}">
        <DockPanel VerticalSpacing="12">

            <!-- Тулбар -->
            <DockPanel 
                DockPanel.Dock="Top" 
                HorizontalSpacing="8"
                LastChildFill="False"
                >
            
                <!-- Поиск -->
			    <TextBox
                    DockPanel.Dock="Left"
                    Width="300" 
                    MaxLength="50"
                    Text="{Binding SearchText}"
                    Watermark="{Binding FilteredItems.Count, StringFormat='Искать среди {0} записей...'}"
                    suki:TextBoxExtensions.Prefix="{icon:MaterialIconExt Kind=Search}"
                    />

                <!-- Добавление -->
                <Button 
                    DockPanel.Dock="Right"
                    Classes="Flat"
                    Content="Добавить"
                    suki:ButtonExtensions.Icon="{icon:MaterialIconExt Kind=Plus}"
                    Command="{Binding AddCommand}"
                    IsVisible="{Binding Permissions.Create}"
                    />
            </DockPanel>

            <suki:GlassCard>
                <Grid>
                    <!-- Таблица -->
			        <DataGrid 
                        ItemsSource="{Binding FilteredItems}"
                        SelectedItem="{Binding SelectedItem}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="True"
                        >
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding EmployeeId}" />
                            <DataGridTextColumn Header="ФИО" Binding="{Binding Fullname}" />
                            <DataGridTextColumn Header="Дата рождения" Binding="{Binding Birthday}" />
                            <DataGridTemplateColumn Header="Действия" Width="Auto">
                                <DataTemplate>
                                    <Menu Height="32" Padding="-2 0">
                                        <MenuItem Height="36" Width="36">
                                            <MenuItem.Header>
                                                <icon:MaterialIcon Kind="DotsVertical" Width="16" />
                                            </MenuItem.Header>
                                            <MenuItem 
                                                Header="Изменить"
                                                Icon="{icon:MaterialIconExt Kind=Edit}"
                                                IsVisible="{Binding $parent[DataGrid].DataContext.Permissions.Update}"
                                                Command="{Binding $parent[DataGrid].DataContext.EditCommand}"
                                                CommandParameter="{Binding}">
                                            </MenuItem>
                                            <MenuItem 
                                                Header="Уволить"
                                                Icon="{icon:MaterialIconExt Kind=Delete}"
                                                IsVisible="{Binding $parent[DataGrid].DataContext.Permissions.Delete}"
                                                Command="{Binding $parent[DataGrid].DataContext.DeleteCommand}"
                                                >
                                            </MenuItem>
                                        </MenuItem>
                                    </Menu>
                                </DataTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Плейсхолдер -->
                    <TextBlock
                        Text="Данные отсутствуют"
                        Margin="8 54 0 0"
                        Classes="h6"
                        IsHitTestVisible="False"
                        IsVisible="{Binding IsEmpty}"
                        />
                </Grid>
            </suki:GlassCard>
        </DockPanel>
    </suki:BusyArea>

</UserControl>