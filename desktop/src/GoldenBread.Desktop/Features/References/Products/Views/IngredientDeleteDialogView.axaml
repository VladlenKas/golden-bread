<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:GoldenBread.Desktop.Features.Procurement.PurchasePositions.ViewModels"
			 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
			 x:Class="GoldenBread.Desktop.Features.Procurement.PurchasePositions.Views.IngredientDeleteDialogView"
			 x:DataType="vm:IngredientDeleteDialogViewModel">

	<StackPanel Spacing="24">

		<suki:GlassCard>
			<StackPanel Spacing="12">
				<DockPanel HorizontalSpacing="8">
					<TextBlock VerticalAlignment="Center" Text="Ингредиент:" />
					<AutoCompleteBox ItemsSource="{Binding Ingredients}"
									 SelectedItem="{Binding SelectedIngredient}"
									 FilterMode="Contains"
									 MinimumPrefixLength="0"
									 Watermark="Выберите ингредиент"/>
				</DockPanel>
			</StackPanel>
		</suki:GlassCard>

		<StackPanel Orientation="Horizontal"
					HorizontalAlignment="Right"
					Spacing="8">
			<Button Content="Отмена"
					Command="{Binding CancelCommand}" />
			<Button Content="Удалить"
					Command="{Binding DeleteCommand}"
					Classes="Danger"/>
		</StackPanel>
	</StackPanel>

</UserControl>