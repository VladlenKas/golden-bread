<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:vm="using:GoldenBread.Desktop.Features.References.Products.ViewModels"
             x:Class="GoldenBread.Desktop.Features.References.Products.Views.ProductsHostPageView"
             x:DataType="vm:ProductsHostPageViewModel">

    <suki:SukiStackPage Margin="-36 0" Content="{Binding ActivePage}"/>
</UserControl>