<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:GoldenBread.Desktop.Features.Statistics.ViewModels"
    xmlns:suki="https://github.com/kikipoulet/SukiUI"
    x:Class="GoldenBread.Desktop.Features.Statistics.Views.StatisticsHostPageView"
    x:DataType="vm:StatisticsHostPageViewModel">

    <suki:SukiStackPage Margin="-36 0" Content="{Binding ActivePage}"/>
</UserControl>