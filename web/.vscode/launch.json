// To launch the site in debug mode, create a browser 
// shortcut with a prepiscode at the end "--remote-debugging-port=9222"

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Yandex",
      "type": "pwa-chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "pathMapping": {
        "/src": "${workspaceFolder}/src"
      },
      "sourceMapPathOverrides": {
        "src/*": "${webRoot}/src/*"
      }
    }
  ]
}

